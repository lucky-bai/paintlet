<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Keep macOS from auto-appending "Start Dictation…" and "Emoji & Symbols"
       to the Edit menu, which are irrelevant to a paint app. Tauri merges this
       file into the generated Info.plist for the macOS bundle. -->
  <key>NSDisabledDictationMenuItem</key>
  <true/>
  <key>NSDisabledCharacterPaletteMenuItem</key>
  <true/>
</dict>
</plist>
