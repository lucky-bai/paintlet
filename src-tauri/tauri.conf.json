{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Paintlet",
  "version": "0.1.0",
  "identifier": "io.efficientnlp.paintlet",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Paintlet",
        "width": 1200,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "maximized": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "GraphicsAndDesign",
    "publisher": "Bai Li",
    "homepage": "https://github.com/lucky-bai/paintlet",
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "copyright": "© 2026 Bai Li",
    "shortDescription": "MS Paint-style image editor for macOS",
    "longDescription": "Paintlet is an MS Paint-style raster image editor for macOS: pencil, brush, shapes, flood fill, text, and selections in a native window.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
